#!/usr/bin/env bash
set -euo pipefail

# Build one typed Python module with mypyc for the standalone musl CPython.
# python-build-standalone musl currently reports a baked
# /install/include/python3.14 INCLUDEPY through raw sysconfig. That path does
# not exist in this repo layout, so this wrapper uses python3-config for all
# C extension flags.

usage() {
  cat <<'EOF'
usage:
  pyext-build [--out-dir DIR] path/to/module.py... [-- mypyc-arg ...]
  pyext-build [--out-dir DIR] --manifest pyext.toml [-- mypyc-arg ...]

Compiles typed Python modules with mypyc and writes extensions to:
  build/mypyc/$REPO_ARCH/<source-dir>/<module><EXT_SUFFIX>

Manifest form reads the top-level `sources = [...]` list from TOML.

Defaults:
  CC="zig cc -target $REPO_ARCH-linux-musl"
  CXX="zig c++ -target $REPO_ARCH-linux-musl"

Set CC or CXX to override the compiler commands.
EOF
}

if [[ $# -lt 1 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

repo_root="${REPO_ROOT:-$(pwd)}"
repo_root="$(cd "$repo_root" && pwd -P)"
repo_arch="${REPO_ARCH:-$(uname -m)}"
case "$repo_arch" in
  amd64) repo_arch=x86_64 ;;
  arm64) repo_arch=aarch64 ;;
esac

manifest=""
out_dir="$repo_root/build/mypyc/$repo_arch"
module_paths=()
mypyc_args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --)
      shift
      mypyc_args=("$@")
      break
      ;;
    --manifest)
      [[ $# -ge 2 ]] || {
        printf 'pyext-build: --manifest requires a path\n' >&2
        exit 2
      }
      manifest="$2"
      shift 2
      ;;
    --out-dir)
      [[ $# -ge 2 ]] || {
        printf 'pyext-build: --out-dir requires a path\n' >&2
        exit 2
      }
      out_dir="$2"
      shift 2
      ;;
    -*)
      printf 'pyext-build: unknown option: %s\n' "$1" >&2
      exit 2
      ;;
    *)
      module_paths+=("$1")
      shift
      ;;
  esac
done
if [[ -n "$manifest" ]]; then
  [[ -f "$manifest" ]] || {
    printf 'pyext-build: manifest not found: %s\n' "$manifest" >&2
    exit 2
  }
  mapfile -t manifest_sources < <(
    python3 - "$manifest" <<'PYEOF'
import pathlib
import sys
import tomllib

data = tomllib.loads(pathlib.Path(sys.argv[1]).read_text())
for source in data.get("sources", []):
  print(source)
PYEOF
  )
  module_paths+=("${manifest_sources[@]}")
fi

if [[ ${#module_paths[@]} -eq 0 ]]; then
  printf 'pyext-build: no module sources provided\n' >&2
  exit 2
fi

for module_path in "${module_paths[@]}"; do
  if [[ ! -f "$module_path" ]]; then
    printf 'pyext-build: module not found: %s\n' "$module_path" >&2
    exit 2
  fi
done

target="${repo_arch}-linux-musl"
toolchain="${REPO_TOOLCHAIN:-}"
zig_bin="$(command -v zig || true)"
if [[ -z "$zig_bin" && -n "$toolchain" && -x "$toolchain/bin/zig" ]]; then
  zig_bin="$toolchain/bin/zig"
fi

python_bin="${PYTHON:-python3}"
python_config="${PYTHON_CONFIG:-python3-config}"
mypyc_bin="${MYPYC:-}"
if [[ -z "$mypyc_bin" && -n "$toolchain" && -x "$toolchain/mypyc/bin/mypyc" ]]; then
  mypyc_bin="$toolchain/mypyc/bin/mypyc"
fi
if [[ -z "$mypyc_bin" ]]; then
  mypyc_bin="$(command -v mypyc || true)"
fi
if [[ -z "$mypyc_bin" ]]; then
  printf 'pyext-build: skip: mypyc not installed; run ./repo.sh true after bootstrap cache includes mypyc\n' >&2
  exit 77
fi

scratch="$(mktemp -d "${TMPDIR:-/tmp}/pyext-build.XXXXXX")"
trap 'rm -rf "$scratch"' EXIT

. "$repo_root/tools/pyext_build_env.sh"
pyext_build_setup_env "$scratch"
python_bin="$PYTHON"
python_config="$PYTHON_CONFIG"

ext_suffix="$("$python_bin" -c 'import sysconfig; print(sysconfig.get_config_var("EXT_SUFFIX") or "")')"
if [[ -z "$ext_suffix" ]]; then
  printf 'pyext-build: cannot determine EXT_SUFFIX\n' >&2
  exit 1
fi

mkdir -p "$out_dir"
for module_path in "${module_paths[@]}"; do
  abs_module="$(cd "$(dirname "$module_path")" && pwd -P)/$(basename "$module_path")"
  rel_module="${abs_module#"$repo_root"/}"
  if [[ "$rel_module" == "$abs_module" ]]; then
    printf 'pyext-build: module must live under repo root: %s\n' "$module_path" >&2
    exit 2
  fi
  mkdir -p "$scratch/$(dirname "$rel_module")"
  cp "$abs_module" "$scratch/$rel_module"
done

scratch_modules=()
for module_path in "${module_paths[@]}"; do
  abs_module="$(cd "$(dirname "$module_path")" && pwd -P)/$(basename "$module_path")"
  rel_module="${abs_module#"$repo_root"/}"
  scratch_modules+=("$rel_module")
done

(
  cd "$scratch"
  "$mypyc_bin" "${mypyc_args[@]}" "${scratch_modules[@]}"
)

for rel_module in "${scratch_modules[@]}"; do
  stem="$(basename "$rel_module" .py)"
  rel_dir="$(dirname "$rel_module")"
  src_so="$(find "$scratch/$rel_dir" -maxdepth 1 -type f -name "$stem*.so" | head -n1)"
  if [[ -z "$src_so" ]]; then
    src_so="$(find "$scratch" -maxdepth 1 -type f -name "$stem*.so" | head -n1)"
  fi
  if [[ -z "$src_so" ]]; then
    src_so="$(find "$scratch" -type f -name "$stem*.so" | head -n1)"
  fi
  if [[ -z "$src_so" ]]; then
    printf 'pyext-build: mypyc completed without producing %s*.so\n' "$stem" >&2
    exit 1
  fi
  final_dir="$out_dir/$rel_dir"
  mkdir -p "$final_dir"
  out_so="$final_dir/$stem$ext_suffix"
  cp "$src_so" "$out_so"
  printf '%s\n' "$out_so"
done
