#!/usr/bin/env python3
from __future__ import annotations

import argparse
import pathlib
import sys
import tomllib
import trace
import unittest


ROOT = pathlib.Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
  sys.path.insert(0, str(ROOT))


def coverage_omit() -> list[str]:
  config_path = ROOT / "pyproject.toml"
  if not config_path.is_file():
    return []
  data = tomllib.loads(config_path.read_text(encoding="utf-8"))
  repo_quality = data.get("tool", {}).get("repo_quality", {})
  raw = repo_quality.get("coverage_omit", [])
  if not isinstance(raw, list):
    return []
  return [str(item) for item in raw if isinstance(item, str)]


def test_dirs(pattern: str | None) -> list[pathlib.Path]:
  if pattern:
    return [ROOT / pattern]
  return sorted(path for path in (ROOT / "tools").iterdir() if path.is_dir() and path.name.endswith("_tests"))


def run_unittest(pattern: str | None) -> int:
  suite = unittest.TestSuite()
  for start_dir in test_dirs(pattern):
    suite.addTests(unittest.defaultTestLoader.discover(str(start_dir)))
  result = unittest.TextTestRunner(verbosity=1).run(suite)
  return 0 if result.wasSuccessful() else 1


def run_trace_coverage(pattern: str | None, minimum: int) -> int:
  tracer = trace.Trace(count=True, trace=False, ignoredirs=[sys.base_prefix, sys.base_exec_prefix])
  code = tracer.runfunc(run_unittest, pattern)
  if code != 0:
    return code
  results = tracer.results()
  counts = results.counts
  total = 0
  hit = 0
  tools_root = ROOT / "tools"
  for path in tools_root.rglob("*.py"):
    if "__pycache__" in path.parts:
      continue
    rel = path.relative_to(ROOT).as_posix()
    if rel.endswith("_tests/__init__.py") or "/__pycache__/" in rel:
      continue
    lines = [
      line
      for line in path.read_text(encoding="utf-8").splitlines()
      if line.strip() and not line.lstrip().startswith("#")
    ]
    total += len(lines)
    for lineno in range(1, len(path.read_text(encoding="utf-8").splitlines()) + 1):
      if (str(path), lineno) in counts:
        hit += 1
  percent = 100.0 if total == 0 else (hit / total) * 100.0
  print(f"test: trace coverage {percent:.1f}% ({hit}/{total})")
  if percent < minimum:
    print(f"test: coverage {percent:.1f}% below minimum {minimum}%", file=sys.stderr)
    return 1
  return 0


def run_coverage(pattern: str | None, minimum: int) -> int:
  try:
    import coverage  # type: ignore[import-not-found]
  except ImportError:
    return run_trace_coverage(pattern, minimum)

  cov = coverage.Coverage(source=[str(ROOT / "tools")], omit=coverage_omit())
  cov.start()
  code = run_unittest(pattern)
  cov.stop()
  cov.save()
  percent = cov.report(show_missing=True)
  if code != 0:
    return code
  if percent < minimum:
    print(f"test: coverage {percent:.1f}% below minimum {minimum}%", file=sys.stderr)
    return 1
  return 0


def main(argv: list[str] | None = None) -> int:
  parser = argparse.ArgumentParser()
  parser.add_argument("--coverage", action="store_true")
  parser.add_argument("--min", type=int, default=85)
  parser.add_argument("--start-dir", default=None)
  args = parser.parse_args(argv)

  if args.coverage:
    return run_coverage(args.start_dir, args.min)
  return run_unittest(args.start_dir)


if __name__ == "__main__":
  raise SystemExit(main())
