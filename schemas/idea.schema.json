{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Idea row",
  "type": "object",
  "required": ["id", "title", "owner", "state", "target"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
