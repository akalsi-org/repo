{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Python extension descriptor",
  "type": "object",
  "required": ["module", "sources"],
  "properties": {
    "module": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
