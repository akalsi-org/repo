{
  "name": "git_hooks",
  "description": "Managed git hook and editor-extension setup behavior.",
  "owns": [
    "tools/setup",
    "tools/git_hooks/**",
    ".agents/facet/git_hooks/**"
  ],
  "consider": [
    {
      "paths": [
        ".agents/repo.json"
      ],
      "skills": [
        "doc-sync"
      ],
      "reason": "VSCode extension setup configuration lives in repo config."
    }
  ],
  "commands": [
    {
      "name": "setup",
      "adr": "docs/adr/0016_quality_bar.md",
      "purpose": "Install / status / uninstall managed git hooks and configured VSCode plugins."
    }
  ],
  "checks": [
    {
      "name": "setup_status",
      "command": "./repo.sh setup --status",
      "closeout": true
    },
    {
      "name": "pre_push_hook",
      "command": "test -x tools/git_hooks/pre-push",
      "closeout": true
    }
  ],
  "docs": [
    {
      "surface": "AGENTS.md",
      "projection": "integrations"
    },
    {
      "surface": "README.md",
      "projection": "integrations"
    }
  ]
}
